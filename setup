#!/usr/bin/env bash
# Jump-in helper: starts local Next.js for development, prints your production webhook URL (Vercel), checks reachability.
# Run: ./setup   or   npm run setup
#
# Optional: SKIP_DEV=1  — skip starting Next.js (webhook URL + reachability only).
# Optional: PRODUCTION_WEBHOOK_URL=https://…/api/webhook  — override deployed webhook URL.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

G="\033[0;32m"
D="\033[0;90m"
B="\033[1m"
X="\033[0m"

PRODUCTION_WEBHOOK_URL="${PRODUCTION_WEBHOOK_URL:-https://de-influencer-sms.vercel.app/api/webhook}"

NEXT_LOG="$(mktemp -t de-influencer-next.XXXXXX)"
NEXT_PID=""

cleanup() {
  if [[ -n "${NEXT_PID}" ]] && kill -0 "${NEXT_PID}" 2>/dev/null; then
    kill "${NEXT_PID}" 2>/dev/null || true
  fi
  rm -f "${NEXT_LOG}"
}
trap cleanup EXIT INT TERM

echo ""
echo -e "${B}De-Influencer SMS — setup${X}"
echo -e "${D}────────────────────────────────────────${X}"
echo ""

PORT=""
if [[ "${SKIP_DEV:-}" == "1" ]]; then
  echo -e "${D}Step 1:${X} ${B}Skipped${X} ${D}(SKIP_DEV=1 — not starting local Next.js.)${X}"
  echo ""
else
  # ── Step 1 ─────────────────────────────────────────────────
  echo -e "${D}Step 1:${X} Starting Next.js dev server…"
  npm run dev >"${NEXT_LOG}" 2>&1 &
  NEXT_PID=$!

  for _ in $(seq 1 90); do
    if grep -q "Ready" "${NEXT_LOG}" 2>/dev/null; then
      PORT="$(grep -E 'Local:.*localhost:[0-9]+' "${NEXT_LOG}" | tail -1 | grep -oE '[0-9]+$' || true)"
      if [[ -n "${PORT}" ]]; then
        break
      fi
    fi
    sleep 1
  done

  if [[ -z "${PORT}" ]]; then
    echo -e "  ${G}●${X} ${B}Failed:${X} could not detect port. Last log lines:"
    tail -20 "${NEXT_LOG}"
    exit 1
  fi

  echo -e "  ${G}●${X} Dev server ${B}ready${X} → ${B}http://localhost:${PORT}${X}"
  echo -e "  ${B}Port:${X} ${PORT}   ${D}(local testing with curl only — Twilio uses Vercel below.)${X}"
  echo ""
fi

# ── Step 2 ─────────────────────────────────────────────────
echo -e "${D}Step 2:${X} Production webhook ${D}(Vercel — Twilio should POST here):${X}"
echo ""
echo -e "  ${B}${PRODUCTION_WEBHOOK_URL}${X}"
echo ""
HTTP_CODE="$(curl -sS -o /dev/null -w "%{http_code}" --max-time 20 "${PRODUCTION_WEBHOOK_URL}" 2>/dev/null || echo "000")"
if [[ "${HTTP_CODE}" == "200" ]]; then
  echo -e "  ${G}●${X} ${D}Reachability:${X} GET returned ${B}200${X} ${D}(route is responding).${X}"
else
  echo -e "  ${D}  Reachability check: HTTP ${HTTP_CODE} ${D}(expected 200 with body “ok” when deploy + env are healthy.)${X}"
fi
echo ""
echo -e "${D}────────────────────────────────────────${X}"
if [[ "${SKIP_DEV:-}" == "1" ]]; then
  echo -e "${G}●${X} ${B}Done.${X} ${D}(No local server was started.)${X}"
else
  echo -e "${G}●${X} ${B}Local dev is running.${X} ${D}Log:${X} ${NEXT_LOG}"
  echo -e "    ${D}Stop:${X} ${B}Ctrl+C${X}"
  echo ""
  wait
fi
